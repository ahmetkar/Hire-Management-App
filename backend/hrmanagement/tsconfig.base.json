{
  "compilerOptions": {
  
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@hrmanagement/source"],
    "baseUrl": ".",
    "paths":{
        "@hrmanagement/error-handler": [
        "lib/error-handler/src/index.ts"
        ],
        "@hrmanagement/prisma":[
          "lib/prisma/index.ts"
        ]
    }
  }
}
